{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.scrapsilvercalculater.com"
        }
      ],
      "destination": "https://scrapsilvercalculater.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(css|js)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
