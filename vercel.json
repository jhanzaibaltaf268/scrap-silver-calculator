{
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/(.*)(.html)$",
      "destination": "/$1/",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.scrapsilvercalculater.com"
        }
      ],
      "destination": "https://scrapsilvercalculater.com/$1",
      "permanent": true
    },
    { "source": "/current-silver-price/",        "destination": "/silver-price-today/",             "permanent": true },
    { "source": "/current-silver-price",          "destination": "/silver-price-today/",             "permanent": true },
    { "source": "/silver-melt-calculator/",       "destination": "/silver-melt-value-calculator/",   "permanent": true },
    { "source": "/silver-melt-calculator",        "destination": "/silver-melt-value-calculator/",   "permanent": true },
    { "source": "/sterling-silver-price/",        "destination": "/925-silver-price-today/",         "permanent": true },
    { "source": "/sterling-silver-price",         "destination": "/925-silver-price-today/",         "permanent": true },
    { "source": "/silver-price/",                 "destination": "/silver-price-today/",             "permanent": true },
    { "source": "/silver-price",                  "destination": "/silver-price-today/",             "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/api/price",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(css|js)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, s-maxage=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/images/:file",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, s-maxage=2592000, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/favicon.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=2592000, s-maxage=2592000, stale-while-revalidate=86400" }
      ]
    }
  ]
}

