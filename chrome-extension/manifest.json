{
  "manifest_version": 3,
  "name": "Scrap Silver Calculator - Live Price",
  "short_name": "Silver Calc",
  "description": "Live silver spot price and instant melt value calculator. Supports 925 sterling, 999 fine, 900 coin silver and more.",
  "version": "1.0.0",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Scrap Silver Calculator",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": ["storage"],

  "host_permissions": [
    "https://scrapsilvercalculater.com/*",
    "https://www.goldapi.io/*",
    "https://data-asg.goldprice.org/*",
    "https://metals.live/*",
    "https://api.metals.live/*"
  ],

  "background": {
    "service_worker": "background.js"
  }
}
